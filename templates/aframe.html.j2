<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Infinigen Scene — {{ manifest.room_type }} (seed {{ manifest.seed }})</title>
  <script src="https://aframe.io/releases/1.6.0/aframe.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/aframe-extras@7/dist/aframe-extras.min.js"></script>
  <style>
    body { margin: 0; overflow: hidden; }
    #info-panel {
      position: fixed;
      top: 10px;
      left: 10px;
      background: rgba(0,0,0,0.7);
      color: #fff;
      padding: 12px 16px;
      border-radius: 8px;
      font-family: monospace;
      font-size: 13px;
      z-index: 1000;
      pointer-events: none;
    }
  </style>
</head>
<body>
  <div id="info-panel">
    {{ manifest.room_type }} | seed {{ manifest.seed }} | {{ manifest.object_count }} objects<br>
    WASD to move · Mouse to look · Click to lock pointer
  </div>

  <a-scene
    renderer="colorManagement: true; physicallyCorrectLights: true"
    background="color: #1a1a2e"
    vr-mode-ui="enabled: true"
  >
    <!-- Preload all object GLBs -->
    <a-assets timeout="30000">
      {% for obj in manifest.objects %}
      <a-asset-item id="{{ obj.name | sanitize_id }}"
                    src="{{ obj.file }}"></a-asset-item>
      {% endfor %}
    </a-assets>

    <!-- Scene objects by category -->
    {% set categories = manifest.objects | map(attribute='category') | unique | list %}
    {% for cat in categories %}
    <!-- {{ cat }} -->
    {% for obj in manifest.objects if obj.category == cat %}
    <a-entity
      id="{{ obj.name | sanitize_id }}"
      gltf-model="#{{ obj.name | sanitize_id }}"
      position="{{ obj.position[0] }} {{ obj.position[1] }} {{ obj.position[2] }}"
      rotation="{{ obj.rotation[0] }} {{ obj.rotation[1] }} {{ obj.rotation[2] }}"
      scale="{{ obj.scale[0] }} {{ obj.scale[1] }} {{ obj.scale[2] }}"
      data-category="{{ cat }}"
    ></a-entity>
    {% endfor %}

    {% endfor %}

    <!-- Lighting -->
    <a-entity light="type: ambient; color: #ffffff; intensity: 0.4"></a-entity>
    <a-entity light="type: directional; color: #ffffff; intensity: 0.8"
              position="2 4 1"
              light="castShadow: true; shadowMapWidth: 2048; shadowMapHeight: 2048">
    </a-entity>
    <a-entity light="type: point; color: #ffeedd; intensity: 0.3; distance: 10"
              position="0 2.5 0">
    </a-entity>

    <!-- Camera rig with WASD movement -->
    <a-entity id="rig" position="0 1.6 3">
      <a-entity camera
                look-controls="pointerLockEnabled: true"
                wasd-controls="acceleration: 20">
      </a-entity>
    </a-entity>
  </a-scene>
</body>
</html>
